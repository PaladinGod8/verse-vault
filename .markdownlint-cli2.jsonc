{
  "config": {
    "default": true,
    "MD013": {
      "line_length": 100,
      "code_blocks": false,
      "tables": false,
    },
    "MD024": {
      "siblings_only": true,
    },
    "MD033": false,
    "MD041": false,
  },
  "ignores": [
    "**/node_modules/**",
    "**/dist/**",
    "**/out/**",
    "**/.vite/**",
    "**/coverage/**",
    "**/playwright-report/**",
    "**/test-results/**",
  ],
}
