{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "projectType": "openSource",
  "incremental": true,
  "typescript": {
    "quoteStyle": "preferSingle",
    "semiColons": "always",
    "lineWidth": 100
  },
  "json": {
    "lineWidth": 100
  },
  "markdown": {
    "lineWidth": 100
  },
  "excludes": [
    "**/node_modules",
    "**/*-lock.json",
    "**/.vite",
    "**/out",
    "**/coverage",
    "**/dist",
    "**/build",
    "**/test-results",
    "**/playwright-report",
    "yarn.lock",
    "package-lock.json"
  ],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.95.0.wasm",
    "https://plugins.dprint.dev/json-0.19.4.wasm",
    "https://plugins.dprint.dev/markdown-0.17.8.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.26.0.wasm"
  ]
}
