#!/bin/sh

LOG_DIR="scripts/logs/githooks"
MAX_FAILURE_LOGS=3
HOOK_NAME="pre-push"
LAST_STAGE_OUTPUT=""
LAST_STAGE_COMMAND=""

run_stage() {
  LAST_STAGE_COMMAND="$*"
  tmp_output="$(mktemp 2>/dev/null || printf '.git/.%s-stage-%s.log' "$HOOK_NAME" "$$")"
  "$@" >"$tmp_output" 2>&1
  status=$?
  LAST_STAGE_OUTPUT="$(cat "$tmp_output")"
  cat "$tmp_output"
  rm -f "$tmp_output"
  return "$status"
}

prune_failure_logs() {
  old_logs="$(ls -1t "$LOG_DIR"/"$HOOK_NAME"-failure-*.log 2>/dev/null | sed -e "1,${MAX_FAILURE_LOGS}d")"
  if [ -z "$old_logs" ]; then
    return
  fi

  printf '%s\n' "$old_logs" | while IFS= read -r file; do
    [ -z "$file" ] && continue
    rm -f -- "$file"
  done
}

persist_failure_log() {
  stage_name="$1"
  status_code="$2"
  block_reason="$3"

  mkdir -p "$LOG_DIR"
  timestamp="$(date -u +%Y%m%dT%H%M%SZ 2>/dev/null || date +%Y%m%dT%H%M%S)"
  log_file="$LOG_DIR/$HOOK_NAME-failure-$timestamp-$$.log"

  {
    echo "hook=$HOOK_NAME"
    echo "timestamp_utc=$timestamp"
    echo "stage=$stage_name"
    echo "exit_code=$status_code"
    echo "reason=$block_reason"
    echo "command=$LAST_STAGE_COMMAND"
    echo ""
    echo "output:"
    printf '%s\n' "$LAST_STAGE_OUTPUT"
  } >"$log_file"

  prune_failure_logs
  echo "[pre-push] Failure log written to $log_file"
}

block_push() {
  stage_name="$1"
  status_code="$2"
  block_reason="$3"

  echo "$block_reason"
  persist_failure_log "$stage_name" "$status_code" "$block_reason"
  exit "$status_code"
}

echo "[pre-push] Running push quality checks..."

if command -v yarn >/dev/null 2>&1; then
  echo "[pre-push] 1/4 format"
  run_stage yarn format
  status=$?
  if [ "$status" -ne 0 ]; then
    block_push "format" "$status" "[pre-push] Push blocked by formatter errors."
  fi

  if ! git diff --quiet -- .; then
    echo "[pre-push] Formatter updated files locally. Continuing push."
  fi

  echo "[pre-push] 2/4 type-check"
  run_stage yarn type-check
  status=$?
  if [ "$status" -ne 0 ]; then
    block_push "type-check" "$status" "[pre-push] Push blocked by type-check."
  fi

  echo "[pre-push] 3/4 lint"
  run_stage yarn lint
  status=$?
  if [ "$status" -ne 0 ]; then
    block_push "lint" "$status" "[pre-push] Push blocked by lint."
  fi

  echo "[pre-push] 4/4 format:check"
  run_stage yarn format:check
  status=$?
  if [ "$status" -ne 0 ]; then
    block_push "format:check" "$status" "[pre-push] Push blocked by format:check."
  fi
else
  echo "[pre-push] 1/4 format"
  run_stage node_modules/.bin/prettier --write .
  status=$?
  if [ "$status" -ne 0 ]; then
    block_push "format" "$status" "[pre-push] Push blocked by formatter errors."
  fi

  if ! git diff --quiet -- .; then
    echo "[pre-push] Formatter updated files locally. Continuing push."
  fi

  echo "[pre-push] 2/4 type-check"
  run_stage node_modules/.bin/tsc --noEmit
  status=$?
  if [ "$status" -ne 0 ]; then
    block_push "type-check" "$status" "[pre-push] Push blocked by type-check."
  fi

  echo "[pre-push] 3/4 lint"
  run_stage node_modules/.bin/eslint --ext .ts,.tsx . --max-warnings=0
  status=$?
  if [ "$status" -ne 0 ]; then
    block_push "lint" "$status" "[pre-push] Push blocked by lint."
  fi

  echo "[pre-push] 4/4 format:check"
  run_stage node_modules/.bin/prettier --check .
  status=$?
  if [ "$status" -ne 0 ]; then
    block_push "format:check" "$status" "[pre-push] Push blocked by format:check."
  fi
fi

echo "[pre-push] All checks passed. Proceeding with push."
exit 0
